<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.jxau.mapper.UserMapper">

    <!--映射结果集-->
    <resultMap id="usermap" type="com.jxau.pojo.UserPO">
        <id column="id" property="id" jdbcType="VARCHAR"></id>
        <result column="login_act" property="loginAct" jdbcType="VARCHAR"></result>
        <result column="pass_word" property="passWord" jdbcType="VARCHAR"></result>
        <result column="nick_name" property="nickName" jdbcType="VARCHAR"></result>
        <result column="nickName" property="nickName" jdbcType="VARCHAR"></result>
        <result column="image_url" property="imageUrl" jdbcType="VARCHAR"></result>
        <result column="phone" property="phone" jdbcType="VARCHAR"></result>
        <result column="open_id" property="openId" jdbcType="VARCHAR"></result>
        <result column="state" property="state" jdbcType="INTEGER"></result>
        <result column="last_time" property="lastTime" jdbcType="DATE"></result>
    </resultMap>


    <select id="getUserByUserId" resultMap="usermap">
        select * from rc_personal.user_table where id = #{id}
    </select>

</mapper>